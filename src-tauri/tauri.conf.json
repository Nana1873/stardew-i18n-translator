{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Stardew i18n Translator",
  "version": "1.3.0",
  "identifier": "io.github.nana1873.stardew-i18n-translator",
  "build": {
    "beforeDevCommand": "corepack pnpm dev:web",
    "devUrl": "http://127.0.0.1:5174",
    "beforeBuildCommand": "corepack pnpm build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Stardew i18n Translator",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": false,
    "icon": ["icons/icon.ico"]
  }
}

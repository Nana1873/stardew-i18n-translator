{
  "name": "stardew-i18n-translator",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "description": "Local desktop tool for Stardew Valley / SMAPI mod i18n translations.",
  "license": "GPL-3.0-or-later",
  "author": "Nana",
  "repository": "https://github.com/Nana1873/stardew-i18n-translator",
  "scripts": {
    "dev": "tauri dev",
    "dev:web": "vite --host 127.0.0.1",
    "build:web": "tsc && vite build",
    "build": "tsc && vite build && tauri build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.14.2",
    "@tauri-apps/api": "^2.9.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.9.0",
    "@testing-library/jest-dom": "^6.9.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.0",
    "jsdom": "^27.0.0",
    "prettier": "^3.7.0",
    "typescript": "^5.9.0",
    "vite": "^7.2.0",
    "vitest": "^4.0.0"
  }
}

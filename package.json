{
  "name": "stardew-i18n-translator",
  "version": "1.3.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "description": "Local desktop tool for Stardew Valley / SMAPI mod i18n translations.",
  "license": "GPL-3.0-or-later",
  "author": "Nana",
  "repository": "https://github.com/Nana1873/stardew-i18n-translator",
  "scripts": {
    "dev": "tauri dev",
    "dev:web": "vite --host 127.0.0.1",
    "build:web": "tsc && vite build",
    "build": "tsc && vite build && tauri build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "version:set": "node scripts/set-version.mjs",
    "check:versions": "node scripts/check-version-sync.mjs",
    "check:links": "node scripts/check-markdown-links.mjs",
    "check:docs": "node scripts/check-version-sync.mjs && node scripts/check-markdown-links.mjs && prettier --check .",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.14.2",
    "@tauri-apps/api": "^2.9.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.9.0",
    "@testing-library/jest-dom": "^6.9.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
